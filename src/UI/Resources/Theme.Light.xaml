<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- توکن‌های رنگی پایه‌ای تم لایت (روشن فلوئنت) -->
    <SolidColorBrush x:Key="ColorAppBackground" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="ColorCardBackground" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ColorCardBorder" Color="#E0E0E0"/>
    
    <!-- متون (کنتراست بالا برای تم روشن جهت پیشگیری از سفیدی روی سفیدی) -->
    <SolidColorBrush x:Key="ColorTextPrimary" Color="#1D1D1D"/>
    <SolidColorBrush x:Key="ColorTextSecondary" Color="#555555"/>
    <SolidColorBrush x:Key="ColorTextMuted" Color="#888888"/>
    
    <!-- رنگ‌های شاخص و دکمه‌ها -->
    <SolidColorBrush x:Key="ColorAccent" Color="#0078D4"/>
    <SolidColorBrush x:Key="ColorAccentHover" Color="#106EBE"/>
    <SolidColorBrush x:Key="ColorButtonForeground" Color="#FFFFFF"/>
    
    <!-- رنگ‌های کنترلی ترنسفر و پیغام‌های هشدار دهنده بهینه شده برای محیط روشن -->
    <SolidColorBrush x:Key="ColorProgressBackground" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="ColorWarningBackground" Color="#FFF9E6"/>
    <SolidColorBrush x:Key="ColorWarningBorder" Color="#FFB900"/>
    <SolidColorBrush x:Key="ColorWarningText" Color="#664600"/>
    <SolidColorBrush x:Key="ColorSystemMessage" Color="#006622"/>

</ResourceDictionary>
